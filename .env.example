# // .env.example
# Archivo de ejemplo para variables de entorno.

# --- Base de Datos (PostgreSQL) ---
# Credenciales para inicializar el contenedor de la base de datos
POSTGRES_USER=tu_usuario_postgres
POSTGRES_PASSWORD=tu_contraseña_segura
POSTGRES_DB=tu_nombre_db

# --- Backend ---
# Cadena de conexión de Prisma a la base de datos.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://tu_usuario_postgres:tu_contraseña_segura@postgres:5432/tu_nombre_db

# Puerto interno donde escuchará el servidor Backend
PORT=4000

# Clave secreta para firmar y verificar los tokens JWT.
JWT_SECRET=tu_secreto_jwt_super_seguro

# --- Frontend ---
# URL base del Backend.
VITE_API_URL=http://localhost:4000
